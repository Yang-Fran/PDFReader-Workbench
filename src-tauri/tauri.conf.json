{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PDF Reader Workbench",
  "version": "2.4.1",
  "identifier": "com.example.pdfreaderworkbench",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PDF Reader Workbench",
        "width": 1600,
        "height": 960,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": [
      "nsis",
      "msi"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "languages": [
          "English",
          "SimpChinese"
        ]
      },
      "wix": {
        "language": [
          "en-US",
          "zh-CN"
        ]
      }
    }
  }
}



